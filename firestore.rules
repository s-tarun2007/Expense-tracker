rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // NOTE: For a real production app, we would restrict this to specific admin UIDs.
      // For this preview app, we'll allow any signed-in user to act as an admin
      // since the application relies on the user logging in to test it.
      allow read, write: if request.auth != null;
    }
  }
}
